# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME=Financial Advisor API
APP_ENV=development
APP_VERSION=0.1.0
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Supabase / Postgres
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
DATABASE_URL=postgresql+psycopg://postgres:password@host:5432/postgres


# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TRADER=
STRIPE_PRICE_QUANT=
STRIPE_PRICE_EXECUTION_ADDON=

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_LLM_PROVIDER=google
DEFAULT_LLM_MODE=fast

# -----------------------------------------------------------------------------
# Market Data
# -----------------------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NEWS=financial_news
QDRANT_COLLECTION_USER_REPORTS=user_reports

# -----------------------------------------------------------------------------
# Embeddings and RAG
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# -----------------------------------------------------------------------------
# Jobs
# -----------------------------------------------------------------------------
INNGEST_APP_ID=financial-advisor-agent
INNGEST_IS_PRODUCTION=false
NEWS_INGESTION_CRON=0 * * * *
DEFAULT_NEWS_TICKERS=AAPL,MSFT,GOOGL,NVDA,TSLA,AMZN,META,VOO,QQQ,VFV

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
NOTIFICATION_SECRET_KEY=

# -----------------------------------------------------------------------------
# Cache / Rate Limit
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
POSTHOG_KEY=
